{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mmhamigaki-com",
  "compatibility_date": "2025-08-03",
  "main": "./src/index.tsx",
  "workers_dev": false,
  "routes": [{ "pattern": "mmhamigaki.com", "custom_domain": true }],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "mmhamigaki-db",
      "database_id": "19386681-f283-49b8-b272-e75e567e18b0",
      "migrations_dir": "migrations",
    },
  ],
}
