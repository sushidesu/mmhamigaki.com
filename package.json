{
  "name": "mmhamigaki.com",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode client && vite build",
    "preview": "wrangler dev --local",
    "deploy": "npm run build && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20251231.0",
    "capnweb": "^0.4.0",
    "hono": "^4.11.3",
    "honox": "^0.1.52",
    "marked": "^17.0.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.17.1",
    "@hono/vite-build": "^1.8.0",
    "@hono/vite-dev-server": "^0.24.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "oxfmt": "^0.21.0",
    "oxlint": "^1.36.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "wrangler": "^4.4.0"
  }
}
